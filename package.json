{
  "name": "claude-code-desktop",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:all": "npm run build:api && npm run build:interface && npm run build",
    "build:api": "cd apps/api && npm run build",
    "build:interface": "cd apps/interface && npm run build",
    "build:mobile": "vite build --outDir apps/api/public --emptyOutDir",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "npm run build:api && tauri dev",
    "tauri:build": "npm run build:all && tauri build",
    "api:generate": "orval --config orval.config.cjs",
    "api:generate:watch": "orval --config orval.config.cjs --watch"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-input/mask": "^1.2.11",
    "@tanstack/react-query": "^4.36.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@xyflow/react": "^12.11.1",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.11.9",
    "lucide-react": "^1.7.0",
    "moment": "^2.30.1",
    "react": "^18.3.1",
    "react-currency-input-field": "^3.10.0",
    "react-datasheet-grid": "^4.11.5",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-icons": "^5.3.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.27.0",
    "react-select": "^5.8.1",
    "react-table": "^7.8.0",
    "react-toastify": "^10.0.6",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@faker-js/faker": "^9.9.0",
    "@iconify/react": "^5.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/react-table": "^7.7.20",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.11.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.9.0",
    "msw": "^2.10.4",
    "orval": "^7.10.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.8"
  }
}
